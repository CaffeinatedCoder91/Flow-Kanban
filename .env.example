# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Edge Functions (set these as Supabase secrets if using demo-login)
# SUPABASE_URL and SUPABASE_ANON_KEY are provided automatically at runtime.
SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (required — powers all AI features)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Upstash Redis (optional — enables rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# CORS (required in production for API access)
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-domain.com

# Demo / guest login (required if guest login is enabled)
VITE_DEMO_PASSWORD=

# Sentry (optional — error tracking)
SENTRY_DSN=
VITE_SENTRY_DSN=
